use flake

# Always point qd at the main checkout's shared ledger, even inside a worktree.
export QD_ROOT="$(cd "$(git rev-parse --git-common-dir 2>/dev/null)/.." 2>/dev/null && pwd)"

# Secrets are NEVER auto-loaded from a tracked path. If you want direnv to
# source local provider credentials, opt in by creating a gitignored
# `.envrc.local` (e.g. put `dotenv_if_exists .env` or `dotenv <your.env>` in
# it). The recommended secure path is the external env-file workflow instead —
# see docs/secure-external-env-file.md (`--env-file` / `ITOTORI_LOCAL_ENV_FILE`).
source_env_if_exists .envrc.local
