{
  "name": "@itotori/app",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "itotori": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "emit:openapi": "UPDATE_OPENAPI_CONTRACT=1 vitest run test/openapi-contract.test.ts",
    "build": "tsc -p tsconfig.json && vite build --outDir web-dist"
  },
  "dependencies": {
    "@itotori/db": "workspace:*",
    "@itotori/ds": "workspace:*",
    "@itotori/localization-bridge-schema": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/parser": "8.0.4",
    "@babel/types": "8.0.4",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "vitest": "^4.1.10"
  }
}
