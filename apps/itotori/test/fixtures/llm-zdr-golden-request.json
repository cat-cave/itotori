                      "additionalProperties": false
                    }
                  ]
                },
                "verdict": { "type": "string", "const": "CANNOT_ASSESS" },
                "severity": { "type": "string", "const": "none" },
                "span": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "spanId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 256,
                          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:#/-]*$"
                        },
                        "surface": { "type": "string", "enum": ["source", "target"] },
                        "text": { "type": "string", "minLength": 1, "maxLength": 1024 }
                      },
                      "required": ["spanId", "surface", "text"],
                      "additionalProperties": false
                    },
                    { "type": "null" }
                  ]
                },
                "category": { "type": "string", "const": "insufficient-evidence" },
                "evidenceIds": {
                  "maxItems": 1024,
