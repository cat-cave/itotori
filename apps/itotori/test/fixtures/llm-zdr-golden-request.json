                        "bibleRenderingIds": {
                          "minItems": 0,
                          "maxItems": 0,
                          "type": "array",
                          "items": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 256,
                            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:#/-]*$"
