                },
                "basis": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "kind": { "type": "string", "const": "wiki-first" },
                        "bibleRenderingIds": {
                          "minItems": 1,
                          "maxItems": 1024,
                          "type": "array",
                          "items": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 256,
                            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:#/-]*$"
                          }
                        }
                      },
                      "required": ["kind", "bibleRenderingIds"],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "kind": { "type": "string", "const": "pure-mtl-ablation" },
                        "bibleRenderingIds": {
                          "minItems": 0,
