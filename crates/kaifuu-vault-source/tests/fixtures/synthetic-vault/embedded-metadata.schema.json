{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vault.local/schemas/embedded-metadata-1.0.json",
  "title": "Vault Embedded Artifact Metadata v1.0",
  "description": "Self-describing metadata embedded at _vault/metadata.json in every repacked vault archive. Mirrors the SQL catalog model but uses external identifiers everywhere so an archive lifted out of the vault remains intelligible. Source/platform/storefront enums expanded post-recon to match the real vocabularies VNDB, DLsite, and EGS use.",
  "type": "object",
  "required": ["schema_version", "embedded_by", "embedded_at", "vault_artifact", "releases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0" },
    "embedded_by":    { "type": "string" },
    "embedded_at":    { "type": "string", "format": "date-time" },

    "vault_artifact": {
      "type": "object",
      "required": ["artifact_kind", "observed_at"],
      "additionalProperties": false,
      "properties": {
        "artifact_kind": {
          "enum": [
            "dlsite_zip", "dlsite_split",
            "installer_exe", "installer_multistep", "disc_image_kit",
            "portable_tree_packed",
            "patch", "dlc", "crack",
            "audio_work", "vr_app", "assets_only",
            "unknown"
          ]
        },
        "is_portable":       { "type": ["boolean", "null"] },
        "original_filename": { "type": ["string", "null"] },
        "original_url":      { "type": ["string", "null"], "format": "uri" },
        "original_sha256":   { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "source_account":    { "type": ["string", "null"] },
        "observed_at":       { "type": "string", "format": "date-time" }
      }
    },

    "releases":     { "type": "array", "items": { "$ref": "#/$defs/release" } },
    "dependencies": { "type": "array", "items": { "$ref": "#/$defs/dependency" } },
    "facts":        { "type": "array", "items": { "$ref": "#/$defs/fact" } },

    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extracted_at":  { "type": "string", "format": "date-time" },
        "repacked_at":   { "type": "string", "format": "date-time" },
        "repack_method": { "type": "string" },
        "tool_version":  { "type": "string" }
      }
    }
  },

  "$defs": {
    "release": {
      "type": "object",
      "required": ["languages", "platforms", "role", "work"],
      "additionalProperties": false,
      "properties": {
        "edition_name": { "type": ["string", "null"] },
        "edition_year": { "type": ["integer", "null"], "minimum": 1980, "maximum": 2100 },
        "release_date": { "type": ["string", "null"], "format": "date" },
        "updated_at":   { "type": ["string", "null"], "format": "date-time" },
        "languages":    { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "platforms":    { "type": "array", "items": { "$ref": "#/$defs/platform" }, "minItems": 1 },
        "subpath":      { "type": ["string", "null"] },
        "store":        { "anyOf": [{ "$ref": "#/$defs/store" }, { "type": "null" }] },
        "drm_model":    { "anyOf": [{ "enum": ["drm-free", "serial-key", "account-bound", "launcher", "steam-drm", "playdrm", "physical-disc", "unknown"] }, { "type": "null" }] },
        "role":         { "enum": ["primary", "dlc", "patch", "translation", "crack", "docs", "bundle_member", "volume_part"] },
        "work":         { "$ref": "#/$defs/work" },
        "relations":    { "type": "array", "items": { "$ref": "#/$defs/release_relation" }, "default": [] }
      }
    },

    "work": {
      "type": "object",
      "required": ["canonical_title", "work_kind"],
      "additionalProperties": false,
      "properties": {
        "canonical_title": { "type": "string" },
        "original_title":  { "type": ["string", "null"] },
        "titles": {
          "type": "array",
          "description": "Per-language localized titles (VNDB exposes up to 4 per VN).",
          "items": {
            "type": "object",
            "required": ["lang", "title"],
            "additionalProperties": false,
            "properties": {
              "lang":        { "type": "string" },
              "title":       { "type": "string" },
              "latin":       { "type": ["string", "null"] },
              "is_official": { "type": ["boolean", "null"] },
              "is_main":     { "type": ["boolean", "null"] }
            }
          },
          "default": []
        },
        "aliases":         { "type": "array", "items": { "type": "string" }, "default": [] },
        "work_kind":       { "enum": ["game", "vn", "audio", "manga", "illust", "video", "vr", "other"] },
        "age_rating":      { "anyOf": [{ "enum": ["all", "r-15", "r-18", "r-18g", "unknown"] }, { "type": "null" }] },
        "series": {
          "type": ["object", "null"],
          "description": "DLsite series membership.",
          "additionalProperties": false,
          "properties": {
            "id":       { "type": "string" },
            "name":     { "type": "string" },
            "position": { "type": ["integer", "null"] },
            "total":    { "type": ["integer", "null"] }
          }
        },
        "length_bucket":   { "type": ["integer", "null"], "minimum": 1, "maximum": 5 },
        "length_minutes":  { "type": ["integer", "null"] },
        "identifiers":     { "type": "array", "items": { "$ref": "#/$defs/identifier" }, "default": [] },
        "producers":       { "type": "array", "items": { "$ref": "#/$defs/producer" }, "default": [] },
        "tags":            { "type": "array", "items": { "$ref": "#/$defs/work_tag" }, "default": [] },
        "relations":       { "type": "array", "items": { "$ref": "#/$defs/work_relation" }, "default": [] }
      }
    },

    "identifier": {
      "type": "object",
      "required": ["source", "kind", "value"],
      "additionalProperties": false,
      "properties": {
        "source": { "enum": [
          "vndb", "egs", "mobygames", "igdb", "wikidata", "moepedia",
          "erogetrailers", "holyseal", "emdb", "playrack", "tgfrontier",
          "dlsite", "dmm", "fanza", "getchu", "getchu_dl",
          "steam", "gog", "itch", "mangagamer", "jast",
          "digiket", "gyutto", "melonbooks", "booth", "fakku", "denpa",
          "jlist", "johren", "nutaku", "playasia", "kagura", "surugaya",
          "toranoana", "animateg",
          "playstation", "nintendo", "xbox_store",
          "twitter", "pixiv", "fantia", "cien", "patreon", "fanbox",
          "website", "manual"
        ] },
        "kind":  { "type": "string" },
        "value": { "type": "string" }
      }
    },

    "producer": {
      "type": "object",
      "required": ["name", "kind", "role"],
      "additionalProperties": false,
      "properties": {
        "name":           { "type": "string" },
        "romaji":         { "type": ["string", "null"] },
        "kind":           { "enum": ["circle", "company", "developer", "publisher", "individual", "imprint", "unknown"] },
        "role":           { "enum": [
          "developer", "publisher", "circle",
          "writer", "illustrator", "art", "chardesign",
          "musician", "theme_song",
          "voice", "cv",
          "translator", "editor", "producer", "director", "programmer",
          "other"
        ] },
        "character_name": { "type": ["string", "null"], "description": "Only meaningful when role='cv' (voice with associated character)." },
        "identifiers":    { "type": "array", "items": { "$ref": "#/$defs/identifier" }, "default": [] }
      }
    },

    "work_tag": {
      "type": "object",
      "required": ["source", "value"],
      "additionalProperties": false,
      "properties": {
        "source":    { "enum": ["dlsite", "vndb", "egs", "manual", "inferred"] },
        "value":     { "type": "string" },
        "display":   { "type": ["string", "null"] },
        "source_id": { "type": ["string", "null"] },
        "category":  { "type": ["string", "null"] },
        "rating":    { "type": ["number", "null"], "minimum": 0, "maximum": 3 },
        "spoiler":   { "type": ["integer", "null"], "enum": [0, 1, 2, null] }
      }
    },

    "work_relation": {
      "type": "object",
      "required": ["kind", "ref"],
      "additionalProperties": false,
      "properties": {
        "kind":        { "enum": ["fandisc", "sequel", "prequel", "original", "side_story", "shared_universe", "remake", "character_overlap", "bundle", "other"] },
        "ref":         { "$ref": "#/$defs/identifier", "description": "External identifier of the related work." },
        "is_official": { "type": ["boolean", "null"] },
        "notes":       { "type": ["string", "null"] }
      }
    },

    "release_relation": {
      "type": "object",
      "required": ["kind", "ref"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "enum": ["translates", "remasters", "bundles", "superseded_by", "patched_by"] },
        "ref":   { "$ref": "#/$defs/identifier", "description": "External identifier of the related release." },
        "notes": { "type": ["string", "null"] }
      }
    },

    "dependency": {
      "type": "object",
      "required": ["kind", "ref"],
      "additionalProperties": false,
      "properties": {
        "kind":  { "enum": ["requires_base", "patches", "translates", "cracks", "extends"] },
        "ref":   { "$ref": "#/$defs/identifier" },
        "notes": { "type": ["string", "null"] }
      }
    },

    "fact": {
      "type": "object",
      "required": ["field", "value", "source", "evidence"],
      "additionalProperties": false,
      "properties": {
        "field":       { "type": "string" },
        "value":       { "type": "string" },
        "source":      { "type": "string" },
        "evidence":    { "enum": ["resolution", "manual", "direct_observation", "source_assertion", "inference"] },
        "observed_at": { "type": ["string", "null"], "format": "date-time" },
        "notes":       { "type": ["string", "null"] }
      }
    },

    "platform": { "enum": [
      "windows", "macos", "linux", "android", "ios", "web", "browser",
      "switch", "wii_u", "wii", "n3ds", "nds", "gba",
      "ps5", "ps4", "ps3", "ps2", "ps1", "psp", "psv",
      "xbox", "xb360", "xboxone", "xsx",
      "pc98", "pc88", "msx", "dos", "fm_towns", "dreamcast", "saturn",
      "mcd", "ngp", "ws", "pce", "sfc", "fc", "neogeo_cd",
      "dvd_player", "bdp",
      "mobile_other", "other", "unknown"
    ] },

    "store": { "enum": [
      "dlsite", "dmm", "fanza", "getchu", "getchu_dl",
      "steam", "mangagamer", "jast", "gog", "itch",
      "digiket", "gyutto", "melonbooks", "booth", "fakku", "denpa",
      "jlist", "johren", "nutaku", "playasia", "kagura", "surugaya",
      "toranoana", "animateg",
      "playstation", "nintendo", "xbox_store",
      "direct", "physical", "unknown"
    ] }
  }
}
