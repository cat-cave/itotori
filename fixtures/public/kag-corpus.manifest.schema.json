{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cat-cave/itotori/fixtures/public/kag-corpus.manifest.schema.json",
  "title": "Itotori Public KAG `.ks` Corpus Manifest",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "SPDX-License-Identifier",
    "fixture",
    "profileBTagInventory",
    "tagInventory",
    "files",
    "aggregateStats"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": "0.1.0"
    },
    "SPDX-License-Identifier": {
      "const": "CC0-1.0"
    },
    "fixture": {
      "type": "object",
      "required": ["id", "title", "kind", "summary", "sourceLocale", "license", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "const": "synthetic"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "sourceLocale": {
          "type": "string",
          "pattern": "^[a-z]{2,3}(-[A-Z0-9]{2,8})*$"
        },
        "license": {
          "type": "object",
          "required": ["spdx", "evidence"],
          "additionalProperties": false,
          "properties": {
            "spdx": {
              "const": "CC0-1.0"
            },
            "evidence": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "provenance": {
          "type": "object",
          "required": ["author", "creationMethod", "rawAssetPolicy"],
          "additionalProperties": false,
          "properties": {
            "author": {
              "type": "string",
              "minLength": 1
            },
            "creationMethod": {
              "type": "string",
              "minLength": 1
            },
            "rawAssetPolicy": {
              "const": "contains-no-copyrighted-game-assets"
            }
          }
        }
      }
    },
    "profileBTagInventory": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "r",
          "l",
          "p",
          "cm",
          "ct",
          "wait",
          "jump",
          "call",
          "return",
          "if",
          "endif",
          "macro",
          "endmacro",
          "eval",
          "image",
          "playbgm"
        ]
      }
    },
    "tagInventory": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      }
    },
    "files": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": [
          "path",
          "role",
          "mediaType",
          "sha256",
          "bytes",
          "tagInventory",
          "redistributable"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^fixtures/public/kaifuu-kag-synthetic-corpus/[A-Za-z0-9._-]+\\.ks$"
          },
          "role": {
            "const": "source-game"
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "tagInventory": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            }
          },
          "redistributable": {
            "const": true
          }
        }
      }
    },
    "aggregateStats": {
      "type": "object",
      "required": ["files", "sourceLocales", "notes"],
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "integer",
          "minimum": 6
        },
        "sourceLocales": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z]{2,3}(-[A-Z0-9]{2,8})*$"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
