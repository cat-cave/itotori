{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cat-cave/itotori/fixtures/public/kaifuu-helper-results/helper-result.schema.json",
  "title": "Kaifuu Helper Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "fixtureId",
    "helperResultId",
    "profileId",
    "helper",
    "capabilityLevel",
    "execution",
    "diagnostic",
    "redaction",
    "secretRefs",
    "proofHashes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0"
    },
    "fixtureId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "helperResultId": {
      "type": "string",
      "minLength": 1
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "helper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["helperId", "helperVersion", "helperKind"],
      "properties": {
        "helperId": {
          "type": "string",
          "minLength": 1
        },
        "helperVersion": {
          "type": "string",
          "minLength": 1
        },
        "helperKind": {
          "type": "string",
          "enum": [
            "staticParser",
            "knownKeyDatabaseImport",
            "wineLocalWindowsHelper",
            "remoteWindowsHelper",
            "manualKeyEntry"
          ]
        }
      }
    },
    "capabilityLevel": {
      "type": "string",
      "enum": [
        "staticAnalysis",
        "localKeyImport",
        "manualEntry",
        "wineLocal",
        "windowsLocal",
        "remoteWindows"
      ]
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "platform",
        "bounded",
        "timeoutMs",
        "durationMs",
        "networkAccess",
        "filesystemAccess"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["notExecuted", "inProcess", "localProcess", "platformHelper", "remoteHelper"]
        },
        "platform": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "bounded": {
          "const": true
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600000
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3600000
        },
        "networkAccess": {
          "type": "boolean"
        },
        "filesystemAccess": {
          "type": "string",
          "enum": ["none", "tempOnly", "readOnlyWorkspace", "localGameReadOnly", "hostInherited"]
        }
      },
      "not": {
        "anyOf": [
          { "required": ["command"] },
          { "required": ["args"] },
          { "required": ["argv"] },
          { "required": ["shell"] },
          { "required": ["env"] },
          { "required": ["environment"] },
          { "required": ["executablePath"] }
        ]
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "success",
            "missing_key",
            "wrong_key",
            "helper_required",
            "helper_unavailable",
            "helper_authorization_denied",
            "helper_timeout",
            "validation_failed",
            "unsupported_protected_executable",
            "redaction_failure"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "redactedLogHash"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_required", "redacted", "failed"]
        },
        "redactedLogHash": {
          "$ref": "#/$defs/sha256Ref"
        }
      }
    },
    "secretRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/secretRefRecord"
      }
    },
    "proofHashes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proofHashRecord"
      }
    }
  },
  "$defs": {
    "secretRefRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirementId", "secretRef", "materialKind"],
      "properties": {
        "requirementId": {
          "type": "string",
          "minLength": 1
        },
        "secretRef": {
          "type": "string",
          "allOf": [
            {
              "pattern": "^(local-secret|os-keychain|secret-manager|prompt):(?!(?:[A-Za-z0-9._-]+/)*\\.\\.(?:/|$))[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
            },
            {
              "not": {
                "pattern": "^(local-secret|os-keychain|secret-manager|prompt):(?:[A-Za-z0-9._-]+/)*[A-Fa-f0-9-]{32,}(?:/|$)"
              }
            },
            {
              "not": {
                "pattern": "^(local-secret|os-keychain|secret-manager|prompt):(?:[A-Za-z0-9._-]+/)*(?=[A-Za-z0-9_-]{22,256}(?:/|$))(?=[A-Za-z0-9_-]*[a-z])(?=[A-Za-z0-9_-]*[A-Z])(?=[A-Za-z0-9_-]*[0-9])[A-Za-z0-9_-]+(?:/|$)"
              }
            },
            {
              "not": {
                "pattern": "^(local-secret|os-keychain|secret-manager|prompt):(?:[A-Za-z0-9._-]+/)*(?=[A-Za-z]{24,256}(?:/|$))(?=[A-Za-z]*[a-z])(?=[A-Za-z]*[A-Z])[A-Za-z]+(?:/|$)"
              }
            }
          ]
        },
        "materialKind": {
          "type": "string",
          "enum": ["fixedBytes", "hexBytes", "utf8String", "archivePassword", "rpgMakerAssetKey"]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4294967295
        },
        "validation": {
          "$ref": "#/$defs/proofHashRecord"
        }
      }
    },
    "proofHashRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "proofHash"],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "decryptHeaderProof",
            "archiveIndexProof",
            "knownPlaintextProof",
            "fixtureRoundTripProof"
          ]
        },
        "proofHash": {
          "$ref": "#/$defs/sha256Ref"
        }
      }
    },
    "sha256Ref": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
