{
  "name": "@itotori/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "verify:permissions": "node scripts/verify-permission-constraints.mjs",
    "verify:event-queue-indexes": "node scripts/verify-event-queue-index-alignment.mjs",
    "test:verify-permissions": "node --test scripts/verify-permission-constraints.test.mjs",
    "test:verify-event-queue-indexes": "node --test scripts/verify-event-queue-index-alignment.test.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:db": "node scripts/run-tests.mjs --require-database",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@itotori/localization-bridge-schema": "workspace:*",
    "@xmldom/xmldom": "^0.9.10",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@babel/parser": "8.0.4",
    "@babel/types": "8.0.4",
    "@types/pg": "^8.20.0",
    "vitest": "^4.1.10"
  }
}
