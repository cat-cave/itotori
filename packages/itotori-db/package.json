{
  "name": "@itotori/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "verify:permissions": "node scripts/verify-permission-constraints.mjs",
    "test:verify-permissions": "node --test scripts/verify-permission-constraints.test.mjs",
    "test": "node scripts/run-tests.mjs",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@itotori/localization-bridge-schema": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "vitest": "^4.1.9"
  }
}
