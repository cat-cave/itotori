{
  "name": "@itotori/ds",
  "version": "0.0.0",
  "private": true,
  "description": "Itotori design system — the Dusk Observatory tokens + React component library.",
  "files": [
    "dist",
    "src",
    "tokens"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./tokens/styles.css",
    "./tokens/*": "./tokens/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "gallery:build": "vite build",
    "gallery:dev": "vite"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
