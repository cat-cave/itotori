{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cat-cave/itotori/suite/scripts/alpha-public-fixture/schemas/provider-proof.schema.json",
  "title": "Alpha Public Fixture Sanitized Provider Proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "fixtureId",
    "providerProofId",
    "mode",
    "sanitized",
    "recordedSource",
    "runs",
    "billedMicrosUsd",
    "zdrEnforcedCount",
    "fallbackUsedCount"
  ],
  "properties": {
    "schemaVersion": { "const": "itotori.alpha-public-fixture.provider-proof.v0" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "fixtureId": { "type": "string", "minLength": 1 },
    "providerProofId": { "type": ["string", "null"], "minLength": 1 },
    "mode": { "const": "recorded" },
    "sanitized": { "const": true },
    "recordedSource": {
      "type": "string",
      "pattern": "^fixtures/(?!private-local/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "origin",
          "providerRunId",
          "status",
          "provider",
          "retryCount",
          "fallbackUsed",
          "fallbackPlan",
          "cost",
          "dataPolicy"
        ],
        "properties": {
          "origin": { "type": "string", "minLength": 1 },
          "providerRunId": { "type": "string", "minLength": 1 },
          "taskKind": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] },
          "provider": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "providerFamily": { "type": ["string", "null"] },
              "providerName": { "type": ["string", "null"] },
              "requestedModelId": { "type": ["string", "null"] },
              "actualModelId": { "type": ["string", "null"] },
              "upstreamProvider": { "type": ["string", "null"] }
            }
          },
          "structuredOutputMode": { "type": ["string", "null"] },
          "retryCount": { "type": "integer", "minimum": 0 },
          "errorClasses": { "type": "array", "items": { "type": "string" } },
          "fallbackUsed": { "type": "boolean" },
          "fallbackPlan": { "type": "array", "items": { "type": "string" } },
          "tokenUsage": { "type": ["object", "null"] },
          "cost": {
            "type": "object",
            "additionalProperties": false,
            "required": ["costKind", "currency", "amountMicrosUsd"],
            "properties": {
              "costKind": { "type": "string", "enum": ["billed", "zero"] },
              "currency": { "type": "string", "minLength": 1 },
              "amountMicrosUsd": { "type": "integer", "minimum": 0 },
              "pricingSnapshotId": { "type": ["string", "null"] }
            }
          },
          "dataPolicy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["zdr"],
            "properties": { "zdr": { "type": "boolean" } }
          }
        }
      }
    },
    "billedMicrosUsd": { "type": "integer", "minimum": 0 },
    "zdrEnforcedCount": { "type": "integer", "minimum": 0 },
    "fallbackUsedCount": { "type": "integer", "minimum": 0 }
  }
}
