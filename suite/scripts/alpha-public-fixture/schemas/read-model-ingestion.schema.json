{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cat-cave/itotori/suite/scripts/alpha-public-fixture/schemas/read-model-ingestion.schema.json",
  "title": "Alpha Public Fixture Dashboard / Read-Model Ingestion Proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "fixtureId",
    "sourceBridgeId",
    "sourceBundleHash",
    "runtimeTargetIds",
    "runtimeObservationStatus",
    "ingestedTraceEventCount",
    "ingestedBranchEventCount"
  ],
  "properties": {
    "schemaVersion": { "const": "itotori.alpha-public-fixture.read-model-ingestion.v0" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "fixtureId": { "type": "string", "minLength": 1 },
    "sourceBridgeId": { "type": "string", "minLength": 1 },
    "sourceBundleHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "targetLocale": { "type": ["string", "null"] },
    "runtimeTargetIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "runtimeObservationStatus": { "type": "string", "minLength": 1 },
    "ingestedTraceEventCount": { "type": "integer", "minimum": 0 },
    "ingestedBranchEventCount": { "type": "integer", "minimum": 0 },
    "providerProofId": { "type": ["string", "null"] }
  }
}
