{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cat-cave/itotori/suite/scripts/alpha-public-fixture/schemas/shared-025-manifest-linkage.schema.json",
  "title": "Alpha Public Fixture SHARED-025 Manifest Linkage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "verticalFixture",
    "sharedManifest",
    "artifacts",
    "verdict",
    "findings"
  ],
  "properties": {
    "schemaVersion": { "const": "itotori.alpha-public-fixture.vertical-linkage.v0" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "verticalFixture": {
      "type": "object",
      "required": ["fixtureId", "sourceBridgeId", "sourceBundleHash", "sourceRevision"],
      "properties": {
        "fixtureId": { "type": "string", "minLength": 1 },
        "publicManifestUri": { "type": "string" },
        "publicManifestHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "sourceBridgeId": { "type": "string", "minLength": 1 },
        "sourceBundleHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "sourceRevision": { "type": "object" },
        "sourceLocale": { "type": ["string", "null"] },
        "targetLocale": { "type": ["string", "null"] }
      }
    },
    "sharedManifest": {
      "type": "object",
      "required": ["proofManifestId", "uri", "hash", "providerProofIds"],
      "properties": {
        "proofManifestId": { "type": "string", "minLength": 1 },
        "uri": {
          "type": "string",
          "pattern": "^fixtures/(?!private-local/)(?!.*\\.\\.)[A-Za-z0-9._/-]+$"
        },
        "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "providerProofIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "benchmarkReportRefHash": {
          "type": ["string", "null"],
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["project", "artifactKind"],
        "properties": {
          "project": { "type": "string", "enum": ["itotori", "kaifuu", "utsushi"] },
          "artifactKind": { "type": "string", "minLength": 1 },
          "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "rerun": {
      "type": "object",
      "properties": {
        "repairedFindingCodes": { "type": "array", "items": { "type": "string" } },
        "priorFindings": { "type": "array" }
      }
    },
    "verdict": { "type": "string", "enum": ["linked", "broken", "unvalidated"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "subject", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["blocking", "warn", "info"] },
          "subject": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
