{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cat-cave/itotori/suite/scripts/alpha-public-fixture/schemas/vertical-manifest.schema.json",
  "title": "Alpha Public Fixture Vertical Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "command",
    "fixtureId",
    "sourceBridgeId",
    "sourceBundleHash",
    "sharedManifest",
    "composedArtifactIds",
    "emittedArtifacts",
    "verdict"
  ],
  "properties": {
    "schemaVersion": { "const": "itotori.alpha-public-fixture.vertical-manifest.v0" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "command": { "const": "vp run alpha:public-fixture" },
    "fixtureId": { "type": "string", "minLength": 1 },
    "sourceBridgeId": { "type": "string", "minLength": 1 },
    "sourceBundleHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "targetLocale": { "type": ["string", "null"] },
    "sharedManifest": {
      "type": "object",
      "required": ["proofManifestId", "uri", "hash", "providerProofIds"],
      "properties": {
        "proofManifestId": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "providerProofIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "composedArtifactIds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bridge",
        "patchExport",
        "patchResult",
        "deltaPackage",
        "runtimeReport",
        "providerProofId",
        "benchmarkRunId"
      ],
      "properties": {
        "bridge": { "type": "string", "minLength": 1 },
        "patchExport": { "type": "string", "minLength": 1 },
        "patchResult": { "type": "string", "minLength": 1 },
        "deltaPackage": { "type": "string", "minLength": 1 },
        "runtimeReport": { "type": "string", "minLength": 1 },
        "providerProofId": { "type": "string", "minLength": 1 },
        "benchmarkRunId": { "type": "string", "minLength": 1 }
      }
    },
    "emittedArtifacts": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "path", "hash"],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "runtime-observation-proof",
              "provider-proof",
              "benchmark-report",
              "read-model-ingestion",
              "shared-025-manifest-linkage"
            ]
          },
          "path": { "type": "string", "minLength": 1 },
          "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "producedBy": { "type": "string" }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["linked", "broken"] },
    "findingCount": { "type": "integer", "minimum": 0 },
    "blockingFindingCount": { "type": "integer", "minimum": 0 }
  }
}
