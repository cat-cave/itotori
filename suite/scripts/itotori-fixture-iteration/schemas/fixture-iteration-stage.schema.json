{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cat-cave/itotori/suite/scripts/itotori-fixture-iteration/schemas/fixture-iteration-stage.schema.json",
  "title": "Itotori Fixture Iteration Stage Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "stageId",
    "artifactId",
    "localeBranchId",
    "sourceRevision",
    "targetLocale",
    "providerProofId",
    "pair",
    "cost",
    "tokenUsage",
    "contentHash",
    "status",
    "detail",
    "findings"
  ],
  "properties": {
    "schemaVersion": { "const": "itotori.fixture-iteration.stage-result.v0" },
    "generatedAt": { "type": "string", "minLength": 1 },
    "stageId": {
      "type": "string",
      "enum": ["import", "draft", "qa", "export", "feedback", "rerun"]
    },
    "artifactId": { "type": "string", "minLength": 1 },
    "localeBranchId": { "type": ["string", "null"] },
    "sourceRevision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceBridgeId", "sourceBundleHash", "sourceRevisionId"],
      "properties": {
        "sourceBridgeId": { "type": ["string", "null"] },
        "sourceBundleHash": { "type": ["string", "null"] },
        "sourceRevisionId": { "type": ["string", "null"] }
      }
    },
    "targetLocale": { "type": ["string", "null"] },
    "providerProofId": { "type": ["string", "null"] },
    "pair": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "modelId": { "type": ["string", "null"] },
        "providerId": { "type": ["string", "null"] },
        "servedModel": { "type": ["string", "null"] },
        "servedProvider": { "type": ["string", "null"] }
      }
    },
    "cost": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["costKind", "currency", "amountMicrosUsd"],
      "properties": {
        "costKind": { "type": "string", "enum": ["billed", "zero"] },
        "currency": { "type": "string", "minLength": 1 },
        "amountMicrosUsd": { "type": "integer", "minimum": 0 }
      }
    },
    "tokenUsage": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["tokensIn", "tokensOut", "tokenCountSource"],
      "properties": {
        "tokensIn": { "type": "integer", "minimum": 0 },
        "tokensOut": { "type": "integer", "minimum": 0 },
        "tokenCountSource": {
          "type": ["string", "null"],
          "enum": ["provider_reported", "deterministic_counter", null]
        }
      }
    },
    "contentHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "status": { "type": "string", "minLength": 1 },
    "detail": { "type": "object" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "stageId", "artifactId", "remediation", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["blocking", "warn", "info"] },
        "stageId": { "type": "string", "minLength": 1 },
        "artifactId": { "type": "string", "minLength": 1 },
        "remediation": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
